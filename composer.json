{
  "name": "atomicdeploy/ashko-wp",
  "description": "Ashco WooCommerce receiver for the Patris Export product-sync contract",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "test": "phpunit",
    "test:js": "node --test tests/js/*.test.js",
    "lint": "php scripts/lint.php",
    "check-package": "pwsh -NoProfile -File scripts/build-plugin.ps1"
  }
}
