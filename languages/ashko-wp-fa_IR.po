msgid "This exact Patris source is not allowed."
msgstr "این منبع دقیق پاتریس در فهرست مجاز نیست."

msgid "The durable sync report did not pass creation readback."
msgstr "بازخوانی ایجاد گزارش پایدار همگام‌سازی موفق نبود."

msgid "The durable report cannot resume because this event projection differs from its first request."
msgstr "گزارش پایدار نمی‌تواند ادامه یابد، زیرا نمای این رویداد با نخستین درخواست آن متفاوت است."

msgid "No WooCommerce product has that exact Serial."
msgstr "هیچ کالای ووکامرس با این Serial دقیق پیدا نشد."

msgid "The durable sync report checkpoint could not be saved."
msgstr "نقطه ذخیره گزارش پایدار همگام‌سازی ثبت نشد."

msgid "Serial must be supplied as a string."
msgstr "Serial باید به‌صورت رشته ارسال شود."

msgid "More than one product shares that exact Serial."
msgstr "بیش از یک کالا همین Serial دقیق را دارد."

msgid "The exact Serial lookup could not be completed."
msgstr "جست‌وجوی دقیق Serial کامل نشد."

msgid "The durable sync report could not be started."
msgstr "گزارش پایدار همگام‌سازی آغاز نشد."

msgid "A per-product report row could not be saved."
msgstr "ردیف گزارش هر کالا ذخیره نشد."

msgid "The Ashko sync receiver needs at least 192 MiB of PHP memory for a complete Patris envelope."
msgstr "گیرنده همگام‌سازی اشکو برای بسته کامل پاتریس حداقل به ۱۹۲ مگابایت حافظه PHP نیاز دارد."

msgid "A valid Ashko sync credential is required."
msgstr "برای همگام‌سازی، اعتبارنامه معتبر اشکو لازم است."

msgid "A Patris contract header does not match the JSON document."
msgstr "یکی از سرآیندهای قرارداد پاتریس با سند JSON مطابقت ندارد."

msgid "A category does not match the product-sync category shape."
msgstr "ساختار یکی از دسته‌ها با قالب همگام‌سازی کالا مطابقت ندارد."

msgid "A category record_hash does not match its typed category."
msgstr "هش رکورد یکی از دسته‌ها با داده دسته مطابقت ندارد."

msgid "A Code cannot be both a category and an excluded record."
msgstr "یک Code نمی‌تواند هم‌زمان دسته و رکورد مستثنا باشد."

msgid "A code cannot be both a product and a tombstone or quarantine entry."
msgstr "یک کد نمی‌تواند هم‌زمان کالا و رکورد حذف یا قرنطینه باشد."

msgid "A Code cannot be both a sellable product and a structural catalog record."
msgstr "یک Code نمی‌تواند هم‌زمان کالای قابل فروش و رکورد ساختاری فهرست باشد."

msgid "A different event already occupies this source timestamp."
msgstr "رویداد دیگری پیش‌تر برای این زمان منبع ثبت شده است."

msgid "A JSON request body is required."
msgstr "بدنه درخواست JSON الزامی است."

msgid "A product category_code must reference the complete category projection."
msgstr "category_code کالا باید به یکی از دسته‌های نمای کامل اشاره کند."

msgid "A product does not match the sparse product-sync shape."
msgstr "ساختار یکی از کالاها با قالب کم‌تراکم همگام‌سازی مطابقت ندارد."

msgid "A product-sync field is invalid."
msgstr "یکی از فیلدهای همگام‌سازی کالا نامعتبر است."

msgid "A record_hash does not match its typed product."
msgstr "هش رکورد با داده کالای مربوطه مطابقت ندارد."

msgid "An update event cannot be applied before its source snapshot."
msgstr "رویداد به‌روزرسانی پیش از تصویر کامل منبع قابل اعمال نیست."

msgid "An update event cannot be validated before its source snapshot."
msgstr "رویداد به‌روزرسانی پیش از تصویر کامل منبع قابل اعتبارسنجی نیست."

msgid "Another product-sync event is being applied. Please retry."
msgstr "رویداد همگام‌سازی دیگری در حال اعمال است؛ دوباره تلاش کنید."

msgid "Category codes must be unique inside an event."
msgstr "کدهای دسته در هر رویداد باید یکتا باشند."

msgid "Deferred product reconciliation failed."
msgstr "تطبیق دوباره کالاهای به‌تعویق‌افتاده ناموفق بود."

msgid "final_price does not match independently evaluated landed_price."
msgstr "final_price با landed_price محاسبه‌شده مستقل مطابقت ندارد."

msgid "final_price must be absent or explicitly null when landed_price inputs are incomplete."
msgstr "وقتی ورودی‌های landed_price کامل نیست، final_price باید حذف شده یا به‌صراحت null باشد."

msgid "Only digitalogic.product-sync envelopes are accepted."
msgstr "فقط بسته‌های digitalogic.product-sync پذیرفته می‌شوند."

msgid "Product codes must be unique inside an event."
msgstr "کدهای کالا در هر رویداد باید یکتا باشند."

msgid "Quarantined codes cannot be tombstoned."
msgstr "کدهای قرنطینه‌شده نمی‌توانند هم‌زمان برای حذف علامت‌گذاری شوند."

msgid "Raw Patris fields are forbidden on the transformed product-sync endpoint."
msgstr "فیلدهای خام پاتریس در درگاه داده تبدیل‌شده همگام‌سازی مجاز نیستند."

msgid "Source id and dataset must be provided together."
msgstr "شناسه منبع و مجموعه‌داده باید با هم ارائه شوند."

msgid "Stored receiver state did not pass readback verification."
msgstr "بازخوانی و تأیید وضعیت ذخیره‌شده گیرنده موفق نبود."

msgid "The combined receiver state is too large."
msgstr "حجم مجموع وضعیت گیرنده بیش از حد مجاز است."

msgid "The configured source limit has been reached."
msgstr "تعداد منابع به حد پیکربندی‌شده رسیده است."

msgid "The database lock service is unavailable."
msgstr "سرویس قفل پایگاه داده در دسترس نیست."

msgid "The envelope contains unsupported fields."
msgstr "بسته شامل فیلدهای پشتیبانی‌نشده است."

msgid "The envelope is missing required fields."
msgstr "برخی فیلدهای الزامی بسته وجود ندارند."

msgid "The event contains too many categories."
msgstr "تعداد دسته‌های رویداد بیش از حد مجاز است."

msgid "The event contains too many products."
msgstr "تعداد کالاهای رویداد بیش از حد مجاز است."

msgid "The event is older than the stored source state."
msgstr "این رویداد از وضعیت ذخیره‌شده منبع قدیمی‌تر است."

msgid "The event_id does not match the canonical event contents."
msgstr "event_id با محتوای معیار رویداد مطابقت ندارد."

msgid "The landed_price formula is required when formula_id is supplied."
msgstr "در صورت ارائه formula_id، فرمول باید landed_price باشد."

msgid "The product-sync event could not be applied."
msgstr "رویداد همگام‌سازی کالا قابل اعمال نبود."

msgid "The product-sync payload is too large."
msgstr "حجم داده همگام‌سازی کالا بیش از حد مجاز است."

msgid "The product-sync payload must be an object."
msgstr "داده همگام‌سازی کالا باید یک شیء JSON باشد."

msgid "The product-sync request is not valid JSON."
msgstr "درخواست همگام‌سازی کالا JSON معتبر نیست."

msgid "The receiver could not start a storage transaction."
msgstr "گیرنده نتوانست تراکنش ذخیره‌سازی را آغاز کند."

msgid "The receiver currently supports IRT output only."
msgstr "گیرنده در حال حاضر فقط خروجی IRT را می‌پذیرد."

msgid "The receiver state could not be stored."
msgstr "وضعیت گیرنده ذخیره نشد."

msgid "The receiver state transaction could not be committed."
msgstr "تراکنش وضعیت گیرنده نهایی نشد."

msgid "The receiver storage service is unavailable."
msgstr "سرویس ذخیره‌سازی گیرنده در دسترس نیست."

msgid "The requested product-sync source was not found."
msgstr "منبع همگام‌سازی درخواستی پیدا نشد."

msgid "The source revision does not match the resulting source snapshot."
msgstr "بازبینی منبع با تصویر کامل حاصل از آن مطابقت ندارد."

msgid "WooCommerce must use IRR before Ashko product mutations are allowed."
msgstr "پیش از تغییر کالاهای اشکو، ارز پایه ووکامرس باید IRR باشد."

